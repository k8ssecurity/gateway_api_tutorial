# =============================================================================
# versions.env — single source of truth for pinned versions
# =============================================================================
#
# setup.sh sources this file. Keep ALL version numbers here so the lab stays
# reproducible and so the same pins can be shared/aligned across the other
# k8ssecurity labs (e.g. the agentic-k8s course).
#
# To bump a version: edit it here only. Last refreshed: May 2026.
#
# NOTE: 01-kind-config.yaml also hard-codes the node image inline (for readers
# who run the manual tutorial without setup.sh). setup.sh passes --image
# "$K8S_NODE_IMAGE" to `kind create`, so this file wins for the scripted path —
# keep the two in sync when you bump K8S_NODE_IMAGE.
# =============================================================================

# Kubernetes node image (kindest/node tag from the kind release below)
K8S_NODE_IMAGE="kindest/node:v1.33.7"   # built by kind v0.31.0

# Networking / CNI
CILIUM_VERSION="1.19.3"

# LoadBalancer (only the one matching $LB_PROVIDER is used; see setup.sh)
METALLB_VERSION="v0.15.3"               # used when LB_PROVIDER=metallb

# Gateway API + data planes
GATEWAY_API_VERSION="v1.5.0"            # Experimental channel
ENVOY_GATEWAY_VERSION="v1.7.3"
AGENTGATEWAY_VERSION="v1.1.0"           # charts at cr.agentgateway.dev/charts/ (decoupled from kgateway since v1.0)
